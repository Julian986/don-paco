generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

/// Catálogo persistido. `lista` = precio de lista; tarjeta y efectivo se calculan como en la tienda.
model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  name        String
  marca       String
  nombre      String
  description String?
  lista       Float
  cash        Float?
  categoryId  String
  stock       Int      @default(5)
  images      String[]
  destacado   Boolean  @default(false)
  /// Slug del grupo (`product-groups.ts`); si se setea, la variante aparece en esa ficha agrupada además del mapa estático.
  groupSlug   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Textos editables desde el admin para la ficha agrupada (card + detalle). `groupSlug` coincide con `product-groups.ts`.
model ProductGroupDisplay {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  groupSlug   String   @unique
  displayName String
  description String?
  /// Imagen de la card / ficha agrupada (URL remota o bajo /public).
  heroImageUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Definición persistida: grupos creados en el panel (`isCustom`) y/o nombre/texto que sobreescribe al mapa estático.
model ProductGroup {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  displayName String
  description String?
  /// Imagen principal del grupo en listado y ficha (sobrescribe mapa estático y fallback por variantes).
  heroImageUrl String?
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Redirección 301 cuando se renombra el slug de un grupo (URLs antiguas).
model GroupSlugRedirect {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  fromSlug  String   @unique
  toSlug    String
  createdAt DateTime @default(now())
}

model Order {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  customerName    String?
  customerEmail   String?
  phone             String?
  status            OrderStatus @default(PENDING)
  total             Float
  currency          String      @default("ARS")
  items             Json
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
